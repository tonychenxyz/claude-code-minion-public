# Slack Bot Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App Token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=xapp-your-app-token

# Claude Code authentication
# Use one of these if you want Claude Code support.
CLAUDE_CODE_OAUTH_TOKEN=your-claude-code-oauth-token
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Codex authentication
# Use this if you want Codex support. If omitted, Codex can still use an
# existing `codex login` auth file when available.
OPENAI_API_KEY=your-openai-api-key

# Default agent for new channels: claude or codex
DEFAULT_AGENT=claude

# Port for internal orchestrator communication
ORCHESTRATOR_PORT=3000

# Working directory for agent commands
# WORKING_DIRECTORY=/path/to/your/workspace

# Claude Code model
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Codex model settings
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=xhigh

# Context window max tokens, used by /context
CONTEXT_WINDOW_MAX=200000

# Optional shared cache locations for large model/data downloads
# HF_HOME=/path/to/claude-code-minion/projects/.cache/huggingface
# TRANSFORMERS_CACHE=/path/to/claude-code-minion/projects/.cache/huggingface
# TORCH_HOME=/path/to/claude-code-minion/projects/.cache/torch
